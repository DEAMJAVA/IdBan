{
	"schemaVersion": 1,
	"id": "id-ban",
	"version": "${version}",
	"name": "Id Ban",
	"description": "It allows server owners to enforce mod restrictions without requiring client installation or intrusive scanning",
	"authors": [
		"DEAMJAVA"
	],
	"contact": {
		"homepage": "https://github.com/DEAMJAVA/IdBan",
		"sources": "https://github.com/DEAMJAVA/IdBan"
	},
	"license": "MIT",
	"icon": "assets/id-ban/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "net.deamjava.id_ban.IdBan",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "net.deamjava.id_ban.IdBanClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"id-ban.mixins.json",
		{
			"config": "id-ban.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}